<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    tools:context=".BulletRewriterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textBulletRewriterTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bullet Rewriter"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBulletRewriterInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Paste a weak resume bullet, choose a target profession, and get an offline rewrite with stronger wording and metric ideas."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editWeakBullet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:autofillHints=""
            android:gravity="top|start"
            android:hint="Example: Helped with reports for the team"
            android:inputType="textMultiLine|textCapSentences"
            android:minHeight="120dp"
            android:padding="12dp"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorHint" />

        <TextView
            android:id="@+id/textProfessionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Target profession"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerProfession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp" />

        <Button
            android:id="@+id/btnRewriteBullet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Rewrite Bullet" />

        <TextView
            android:id="@+id/textRewriteOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:lineSpacingExtra="4dp"
            android:text="Your rewritten bullet will appear here."
            android:textColor="?android:attr/textColorPrimary"
            android:textIsSelectable="true"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
