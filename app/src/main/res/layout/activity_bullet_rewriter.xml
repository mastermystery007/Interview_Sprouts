<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textBulletRewriterTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bullet Rewriter"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBulletSourceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="No clear resume bullets detected. Paste a bullet manually."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp" />

        <Spinner
            android:id="@+id/spinnerResumeBullets"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#F7F7F7"
            android:minHeight="48dp"
            android:padding="8dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/editWeakBullet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:autofillHints=""
            android:background="#F7F7F7"
            android:gravity="top|start"
            android:hint="Example: Helped with reports for the team"
            android:inputType="textMultiLine|textCapSentences"
            android:minHeight="120dp"
            android:padding="12dp"
            android:textColor="#111111"
            android:textColorHint="#777777" />

        <TextView
            android:id="@+id/textProfessionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Target profession"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerProfession"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#F7F7F7"
            android:padding="8dp" />

        <Button
            android:id="@+id/btnRewriteBullet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Rewrite Bullet" />

        <TextView
            android:id="@+id/textRewriteOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:lineSpacingExtra="4dp"
            android:text="Your rewritten bullet will appear here."
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
