<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumeInputRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_hero"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Resume Review"
                android:textAlignment="center"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Upload or paste your resume, then compare it against a target role or job description."
                android:textAlignment="center"
                android:textColor="#334155"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_file_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Resume"
                android:textAlignment="center"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Upload a PDF or DOCX, or paste resume text below. Extracted text remains editable."
                android:textColor="#475569"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnUploadPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Upload PDF or DOCX" />

            <TextView
                android:id="@+id/textAttachedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No file attached"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textExtractionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Upload a file or paste resume text before analysis."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Resume text"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editResumeText"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="Paste your resume text here, or edit the text extracted from your PDF or DOCX."
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#111111"
                android:textColorHint="#777777" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Target details"
                android:textAlignment="center"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Target role"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTargetRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input_field"
                android:minHeight="48dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Experience"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerExperienceLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input_field"
                android:minHeight="48dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Paste JD for tailored matching (optional)"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editJobSpecification"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="Paste the job description here to get more accurate requirement weighting, evidence matching, and JD-specific interview questions."
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="#111111"
                android:textColorHint="#777777" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Privacy: Diamond Star analysis sends resume text and JD to our backend only after the second unlock."
            android:textColor="#64748B"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnAnalyzeResume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Analyze Resume" />

    </LinearLayout>
</ScrollView>
