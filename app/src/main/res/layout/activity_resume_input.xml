<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumeInputRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resume Review"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload your resume PDF and add job details for better feedback."
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnUploadPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Resume PDF" />

        <TextView
            android:id="@+id/textAttachedFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No file attached"
            android:textColor="#111111"
            android:textSize="14sp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/textExtractionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload a PDF resume before analysis."
            android:textColor="#555555"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Profession"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <Spinner
            android:id="@+id/spinnerTargetRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_marginTop="8dp"
            android:background="#F2F2F2"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Experience Level"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerExperienceLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_marginTop="8dp"
            android:background="#F2F2F2"
            android:padding="8dp" />

        <EditText
            android:id="@+id/editJobSpecification"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:gravity="top"
            android:hint="Optional: Paste job specification / job description here..."
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="#111111"
            android:textColorHint="#777777"
            android:background="#F7F7F7"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: Job specifications help find missing skills, tools, keywords, and responsibilities for the exact role."
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your resume is processed for feedback. Advanced AI review sends resume text and job description to our backend only after you unlock it."
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnAnalyzeResume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analyze Resume"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>