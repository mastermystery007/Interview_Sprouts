<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_hero"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imageAppLogo"
                android:layout_width="220dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="InterviewSprout logo"
                android:scaleType="fitCenter"
                android:src="@drawable/interviewsprout_logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Resume feedback, JD matching, and AI interview prep."
                android:textColor="#334155"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="Start here"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnResumeReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="56dp"
            android:text="Resume Review" />

        <Button
            android:id="@+id/btnSavedReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="56dp"
            android:text="Saved Reports" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_form_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:text="Upload a resume PDF, choose a target role, and unlock deeper feedback with simulated rewarded ads."
            android:textColor="#475569"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
