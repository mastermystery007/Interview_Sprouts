<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBackSavedReportDetail"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:text="‹ Back"
            android:textColor="#0B63CE"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Saved Report"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSavedReportDetailMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_saved_header_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textSavedReportDetailBasic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textSavedReportDetailFull"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Use This Report"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCopySavedReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Copy Report" />

        <Button
            android:id="@+id/btnShareSavedReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Share Report" />

        <Button
            android:id="@+id/btnExportSavedReportPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Export Report as PDF" />

        <TextView
            android:id="@+id/textSavedReportDetailNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Saved reports are stored locally on this device only."
            android:textColor="#555555"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
