<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumeReportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textReportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resume Report"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTargetRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Role"
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/textOverallScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="72 / 100"
            android:textColor="#111111"
            android:textSize="42sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/textScoreLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overall Resume Score"
            android:textColor="#333333"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textBasicFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#111111"
            android:textSize="15sp"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textMissingKeywordsHook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#111111"
            android:textSize="15sp"
            android:background="#F2F2F2"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textLockedReportMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#F7F7F7"
            android:padding="14dp"
            android:text="Full bullet rewrites, detailed scoring, and interview questions are locked. Watch an ad to unlock."
            android:textColor="#111111"
            android:textSize="15sp"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textIsSelectable="true" />

        <Button
            android:id="@+id/btnUnlockFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Watch Ad to Unlock Full Report"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/textFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#111111"
            android:textSize="15sp"
            android:visibility="gone"
            android:layout_marginTop="20dp"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textUnlockedBulletSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none" />

        <TextView
            android:id="@+id/textUnlockedInterviewQuestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none" />

        <TextView
            android:id="@+id/textAdvancedLockedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#F7F7F7"
            android:padding="14dp"
            android:text="Advanced AI review, tailored job-description suggestions, and deeper interview questions are locked. Watch another ad to unlock."
            android:textColor="#111111"
            android:textSize="15sp"
            android:visibility="gone"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textIsSelectable="true" />

        <Button
            android:id="@+id/btnUnlockAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Watch Ad to Unlock Advanced AI Review"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textIsSelectable="true"
            android:singleLine="false"
            android:maxLines="1000"
            android:ellipsize="none"
            android:scrollHorizontally="false"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSaveReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Report Locally"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
