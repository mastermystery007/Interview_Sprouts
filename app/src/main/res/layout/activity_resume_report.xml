<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumeReportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="‹"
                android:textColor="#111111"
                android:textSize="34sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textReportTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="InterviewSprout · Score Analysis"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textReportSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#555555"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/scoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_score_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resume Match Score"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.example.interviewsprouts.ScoreCircleView
                    android:id="@+id/scoreCircleView"
                    android:layout_width="132dp"
                    android:layout_height="132dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textScoreValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#111111"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textAlignmentLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#0B63CE"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textJdChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:textColor="#333333"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textScoreTargetRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textScoreExperience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#555555"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipTargetRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingTop="7dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:textColor="#333333"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipExperienceLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingTop="7dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:textColor="#333333"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipJdStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingTop="7dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:textColor="#333333"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textBasicFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textMissingKeywordsHook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabOverview"
                    style="@style/ResumeReportTab"
                    android:text="Overview" />

                <TextView
                    android:id="@+id/tabStrengths"
                    style="@style/ResumeReportTab"
                    android:text="Strengths" />

                <TextView
                    android:id="@+id/tabGaps"
                    style="@style/ResumeReportTab"
                    android:text="Gaps" />

                <TextView
                    android:id="@+id/tabKeywords"
                    style="@style/ResumeReportTab"
                    android:text="Keywords" />

                <TextView
                    android:id="@+id/tabBespoke"
                    style="@style/ResumeReportTab"
                    android:text="Bespoke" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/textTabContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textLockedReportMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_locked_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:text="Full heuristic analysis and resume-based questions are locked. Watch an ad to unlock."
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnUnlockFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Watch Ad to Unlock Full Report" />

        <TextView
            android:id="@+id/textFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textUnlockedPointSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textUnlockedInterviewQuestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textAdvancedLockedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_locked_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnUnlockAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Watch Ad to Unlock Advanced AI Review"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textLocalSaveNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="#555555"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSaveReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Save Report Locally" />
    </LinearLayout>
</ScrollView>
