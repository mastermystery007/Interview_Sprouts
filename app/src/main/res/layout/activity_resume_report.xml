<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumeReportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="‹"
                android:textColor="#111111"
                android:textSize="34sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textReportTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Score Analysis"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textReportSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#555555"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/scoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_score_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resume Match Score"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.example.interviewsprouts.ScoreCircleView
                    android:id="@+id/scoreCircleView"
                    android:layout_width="116dp"
                    android:layout_height="116dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textScoreValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="none"
                        android:includeFontPadding="true"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textAlignmentLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#0B63CE"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textJdChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:singleLine="false"
                        android:maxLines="2"
                        android:ellipsize="none"
                        android:breakStrategy="simple"
                        android:gravity="center_vertical"
                        android:textColor="#333333"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textScoreTargetRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textScoreExperience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#555555"
                android:textSize="14sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipTargetRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="190dp"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:singleLine="false"
                    android:maxLines="2"
                    android:ellipsize="none"
                    android:breakStrategy="simple"
                    android:gravity="center_vertical"
                    android:textColor="#333333"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipExperienceLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:singleLine="false"
                    android:maxLines="2"
                    android:ellipsize="none"
                    android:breakStrategy="simple"
                    android:gravity="center_vertical"
                    android:textColor="#333333"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipJdStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:singleLine="false"
                    android:maxLines="2"
                    android:ellipsize="none"
                    android:breakStrategy="simple"
                    android:gravity="center_vertical"
                    android:textColor="#333333"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Quick Review"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBasicFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textMissingKeywordsHook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <HorizontalScrollView
            android:id="@+id/tabScrollContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabGaps"
                    style="@style/ResumeReportTab"
                    android:text="Top Improvement" />

                <TextView
                    android:id="@+id/tabStrengths"
                    style="@style/ResumeReportTab"
                    android:text="Strengths" />

                <TextView
                    android:id="@+id/tabKeywords"
                    style="@style/ResumeReportTab"
                    android:text="Keywords" />

                <TextView
                    android:id="@+id/tabBespoke"
                    style="@style/ResumeReportTab"
                    android:text="JD Match" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/textTabContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/headerUnlockDetailed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Gold Star Analysis"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="visible" />

        <TextView
            android:id="@+id/textLockedReportMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_locked_ad_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:text="See your highest-priority improvements, role and JD keyword coverage, section quality, and detailed score breakdown."
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnUnlockFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Watch Ad to View Analysis" />

        <TextView
            android:id="@+id/headerDetailedAnalysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Detailed Analysis"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textFullReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/headerUnlockAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Unlock Diamond Star Analysis"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textAdvancedLockedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_advanced_locked_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnUnlockAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Watch Ad to Unlock Diamond Star Analysis"
            android:visibility="gone" />

        <TextView
            android:id="@+id/headerAdvancedReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Diamond Star Analysis"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textAdvancedLlmReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_content_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:singleLine="false"
            android:ellipsize="none"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:includeFontPadding="true"
            android:textColor="#111111"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Save Report"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textLocalSaveNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="#555555"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSaveReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Save Report Locally" />
    </LinearLayout>
</ScrollView>
